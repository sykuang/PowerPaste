{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PowerPaste",
  "version": "0.1.3",
  "identifier": "com.primattek.powerpaste",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "PowerPaste",
        "width": 980,
        "height": 240,
        "visible": false,
        "decorations": false,
        "resizable": true,
        "alwaysOnTop": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": false,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "infoPlist": "Info.plist",
      "signingIdentity": null
    },
    "icon": [
      "icons/128x128.png",
      "icons/32x32.png",
      "icons/256x256.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sykuang/PowerPaste/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_ME_WITH_BASE64_PUBLIC_KEY"
    }
  }
}
