{
  "name": "powerpaste",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npm run test:e2e:appium && npm run test:playwright",
    "appium:start": "appium --relaxed-security --port 4723 &",
    "wda:start": "bash tests/e2e/appium/scripts/start-wda-mac.sh",
    "wda:stop": "bash tests/e2e/appium/scripts/stop-wda-mac.sh",
    "test:e2e:mac": "bash tests/e2e/appium/scripts/run-mac-tests.sh",
    "test:e2e:mac:manual": "wdio run tests/e2e/appium/wdio.mac.conf.ts",
    "test:e2e:mac:fast": "POWERPASTE_WDA_PRESTARTED=true wdio run tests/e2e/appium/wdio.mac.conf.ts",
    "test:e2e:mac:permissions": "wdio run tests/e2e/appium/wdio.mac.conf.ts --spec tests/e2e/appium/specs/mac/permissions-dialog.spec.ts",
    "test:e2e:windows": "wdio run tests/e2e/appium/wdio.windows.conf.ts",
    "test:e2e:appium": "node -e \"process.platform === 'darwin' ? require('child_process').execSync('npm run test:e2e:mac', {stdio: 'inherit'}) : require('child_process').execSync('npm run test:e2e:windows', {stdio: 'inherit'})\"",
    "test:playwright": "playwright test --config=tests/e2e/playwright/playwright.config.ts",
    "tauri": "tauri",
    "install:dmg": "DMG=$(ls src-tauri/target/release/bundle/dmg/*.dmg | head -1) && hdiutil attach \"$DMG\" && cp -R '/Volumes/PowerPaste/PowerPaste.app' /Applications/ && hdiutil detach '/Volumes/PowerPaste'",
    "icons:generate": "bash scripts/generate-icons.sh"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/ci-info": "^2.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@wdio/appium-service": "^9.23.2",
    "@wdio/cli": "^9.23.2",
    "@wdio/globals": "^9.23.0",
    "@wdio/local-runner": "^9.23.2",
    "@wdio/mocha-framework": "^9.23.2",
    "@wdio/spec-reporter": "^9.23.2",
    "@wdio/types": "^9.23.2",
    "ci-info": "^4.4.0",
    "expect-webdriverio": "^5.6.4",
    "get-port-please": "^3.2.0",
    "jsdom": "^26.0.0",
    "tree-kill": "^1.2.2",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.2",
    "webdriverio": "^9.23.2"
  }
}
