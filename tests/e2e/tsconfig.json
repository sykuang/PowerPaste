{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node", "mocha", "@wdio/globals/types"],
    "lib": ["ES2022"]
  },
  "include": [
    "appium/**/*.ts",
    "playwright/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
